# AgentsMem Web 环境变量

# API URL（供前端引用）
NEXT_PUBLIC_API_URL=https://agentsmem.com/api/v1

# 后端 URL，供服务端代理：/api/v1/* 会转发到此（同机部署示例：http://127.0.0.1:3011）
# AGENTSMEM_API_URL=http://127.0.0.1:3011

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Sentry
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
